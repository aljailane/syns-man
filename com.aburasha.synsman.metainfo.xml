<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.aburasha.synsman</id>

  <name>SYNS Man</name>
  <summary>SSH / SFTP Manager</summary>

  <metadata_license>MIT</metadata_license>
  <project_license>MIT</project_license>

  <description>
    <p>
      SYNS Man is a modern, cross-platform SSH and SFTP manager built with Electron.
      It lets you manage multiple remote servers from a clean graphical interface —
      no terminal required for everyday tasks.
    </p>
    <ul>
      <li>SSH terminal with full xterm.js support</li>
      <li>SFTP file manager: upload, download, delete, rename, chmod</li>
      <li>In-app file editor with syntax highlighting (CodeMirror)</li>
      <li>Password and SSH key authentication (id_rsa, id_ed25519, id_ecdsa, *.pem)</li>
      <li>Encrypted credential storage</li>
      <li>Multi-color themes: Dark, Light, Ocean, Forest, Violet, Rose</li>
      <li>In-app changelog fetched live from GitHub</li>
      <li>Update notifications via GitHub Releases API</li>
    </ul>
  </description>

  <url type="homepage">https://aljailane.github.io/syns-man/</url>
  <url type="bugtracker">https://github.com/aljailane/syns-man/issues</url>
  <url type="vcs-browser">https://github.com/aljailane/syns-man</url>

  <developer id="com.aburasha">
